# Environment Variables for PraGo Portfolio

# Pexels API Key (for My Clicks photography page)
# Get your API key from: https://www.pexels.com/api/
NEXT_PUBLIC_PEXELS_API_KEY=your_pexels_api_key_here

# WHOIS API Key (optional - for Domain Stats page)
# Free tier available at: https://www.whoisxmlapi.com/
# The app will use the free tier if this is not set
# Upgrade to paid tier for higher rate limits and more features
WHOIS_API_KEY=your_whois_api_key_here
